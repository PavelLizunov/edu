{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(rm -rf*)",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"deny\",\"permissionDecisionReason\":\"rm -rf заблокирован — используй точечное удаление\"}}' && exit 2"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "cd $CLAUDE_PROJECT_DIR && [ -f package.json ] && bun run lint --quiet 2>&1 | tail -30 || true"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(bun *)",
      "Bash(bunx *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git checkout*)",
      "Bash(git branch*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git restore*)",
      "Bash(git stash*)",
      "Bash(git rev-parse*)",
      "Bash(git ls-files*)",
      "Bash(git fetch*)",
      "Bash(git pull*)",
      "Bash(git push origin main)",
      "Bash(git push)",
      "Bash(node --version)",
      "Bash(bun --version)",
      "Bash(ls*)",
      "Bash(mkdir *)",
      "Bash(mkdir -p*)",
      "Bash(mv *)",
      "Bash(cp *)",
      "Bash(touch *)",
      "Bash(rm *)",
      "Bash(rmdir *)",
      "Bash(cat *)",
      "Bash(head*)",
      "Bash(tail*)",
      "Bash(echo *)",
      "Bash(pwd)",
      "Bash(which *)",
      "Bash(curl -fsSL https://bun.sh/install*)",
      "Bash(curl -fsSL https://github.com/oven-sh/bun/*)",
      "Bash(/home/appuser/.bun/bin/bun *)",
      "Bash(/home/appuser/.bun/bin/bunx *)",
      "Bash(~/.bun/bin/bun *)",
      "Bash(source*)",
      "Bash(. *)",
      "Bash(export *)",
      "Bash(docker compose config*)",
      "Bash(docker compose build*)",
      "Bash(docker compose ps*)",
      "Bash(ssh user@192.168.0.207 *)",
      "Bash(ssh user@192.168.0.236 *)",
      "Bash(ssh user@192.168.0.142 *)",
      "Bash(ssh -o BatchMode=yes*)",
      "Bash(rsync*)",
      "Bash(scp *)",
      "Read",
      "Glob",
      "Grep",
      "Write",
      "Edit",
      "WebFetch"
    ],
    "ask": [
      "Bash(git push --force*)",
      "Bash(wget*)",
      "Bash(docker compose up*)",
      "Bash(docker compose down*)",
      "Bash(docker compose restart*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Bash(rm -rf*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)"
    ]
  }
}
